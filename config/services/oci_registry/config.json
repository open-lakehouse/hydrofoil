{
  "distSpecVersion": "1.1.1",
  "storage": {
    "rootDirectory": "/var/lib/registry",
    "dedupe": true,
    "remoteCache": false,
    "storageDriver": {
      "name": "s3",
      "rootdirectory": "/",
      "region": "hydrofoil",
      "bucket": "oci-registry",
      "secure": true,
      "skipverify": true,
      "regionendpoint": "http://seaweedfs:8333",
      "forcepathstyle": true
    }
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000"
  },
  "log": {
    "level": "warn"
  },
  "extensions": {
    "search": {
      "enable": true
    },
    "ui": {
      "enable": true
    },
    "trust": {
      "enable": true,
      "cosign": true,
      "notation": true
    }
  }
}
