# Install all workspace dependencies
install:
    npm install

# Lint all TypeScript (check only)
lint:
    npm run lint

# Lint and auto-fix TypeScript
lint-fix:
    npm run lint:fix

# Start the UI dev server (Vite, localhost:3002)
ui-dev:
    npm run dev --prefix ui

# Build the UI for production
ui-build:
    npm run build --prefix ui

# Run the UI unit tests (incl. the Storybook fixture-validation gate)
ui-test:
    npm run test --prefix ui

# Launch Storybook to explore UI components in isolation (no backend needed —
# the .storybook host serves the curated fixtures at the UI's seams).
ui-storybook:
    npm run storybook --prefix ui

# Build the static Storybook bundle (storybook-static/)
ui-storybook-build:
    npm run build-storybook --prefix ui

# Absolute path to the sibling unitycatalog-rs repo + the built uc binary,
# derived from this justfile's location (node/ → repo root → its sibling) so
# tasks work from any cwd. Override the binary with OPEN_LAKEHOUSE_UC_BIN.
uc_repo := justfile_directory() / ".." / ".." / "mangrove"
uc_binaries := justfile_directory() / "desktop" / "src-tauri" / "binaries"
uc_wheels := justfile_directory() / "desktop" / "wheels"

# Build the sibling unitycatalog-rs `uc` server and symlink it as the Tauri
# sidecar binary (binaries/uc-server-<target-triple>, per tauri.conf.json
# externalBin). Run once (and after moving/rebuilding uc). Override the source
# binary with OPEN_LAKEHOUSE_UC_BIN. Tauri resolves the triple-suffixed sidecar
# itself, so no absolute-path scope wrangling.
[script('bash', '-eu')]
uc-setup:
    cargo build -p olai-uc-cli --release --bin uc \
        --manifest-path "{{ uc_repo }}/Cargo.toml"
    src="${OPEN_LAKEHOUSE_UC_BIN:-{{ uc_repo }}/target/release/uc}"
    uc_bin="$(cd "$(dirname "$src")" && pwd)/$(basename "$src")"
    triple="$(rustc -vV | sed -n 's/^host: //p')"
    mkdir -p "{{ uc_binaries }}"
    ln -sf "$uc_bin" "{{ uc_binaries }}/uc-server-$triple"
    echo "linked {{ uc_binaries }}/uc-server-$triple -> $uc_bin"

# Build a NATIVE-host wheel of the sibling unitycatalog-rs Python client (with the
# `obstore` extra) into node/desktop/wheels, where the desktop marimo launch
# points uv (UV_FIND_LINKS) so notebook cells can `import unitycatalog_client` /
# build a UC-vended obstore store. Unlike unitycatalog-rs's `build-py-wheels`
# (which cross-compiles manylinux wheels via zig for the Docker image), this
# builds for THIS host (macOS), since desktop runs marimo natively. The wheel is
# abi3 (pyo3 abi3-py39), so one wheel covers every Python >= 3.9. Run once for a
# dev checkout; rerun after updating the sibling client. Requires `maturin` + `uv`.
[script('bash', '-eu')]
build-uc-wheel:
    mkdir -p "{{ uc_wheels }}"
    uv run --project "{{ uc_repo }}" maturin build --release \
        --manifest-path "{{ uc_repo }}/python/client/Cargo.toml" \
        --out "{{ uc_wheels }}"
    echo "built unitycatalog-client wheel into {{ uc_wheels }}"

# Run the Tauri desktop app in dev with the embedded Unity Catalog server (SQLite
# persisted under node/desktop/.uc-data/). Requires `just uc-setup` first. The
# desktop spawns + manages `uc` and points the in-process host at it; UC REST is
# proxied to it through tauriFetch.
desktop-dev:
    npm run tauri:dev --prefix desktop

# Run the desktop app with NO Unity Catalog — files use the in-memory store. Handy
# for quick smoke tests that don't need a catalog.
desktop-dev-mem:
    OPEN_LAKEHOUSE_UC_URL= npm run tauri:dev --prefix desktop

# Build the Tauri desktop app bundle
desktop-build:
    npm run tauri:build --prefix desktop

# Regenerate the Unity Catalog OpenAPI TypeScript client
gen-api:
    npm run gen:api --prefix uc-client

# Regenerate the JSON Schemas backing the UI's schema-driven forms.
# Drives the buf protoschema-jsonschema plugin against the unitycatalog-rs protos
# (pinned to the same git rev as the Cargo deps). Requires `buf` + network.
gen-forms:
    npm run gen:form-schemas --prefix uc-client

# Regenerate the JSON Schemas that validate the Storybook fixtures (portal
# Tags/Files domain models via buf + Unity Catalog entity Info types from the
# committed OpenAPI spec). See node/ui/scripts/gen-fixture-schemas.mjs.
gen-fixture-schemas:
    npm run gen:fixture-schemas --prefix ui

# Regenerate the connect-es TypeScript client for hydrofoil's QueryService.
# Driven by buf against proto/hydrofoil-query (the repo-root proto tree).
gen-rpc:
    npm run gen:rpc --prefix ui

# Regenerate everything derived from protos/specs (UC client + form schemas + RPC
# client + Storybook fixture schemas)
gen: gen-api gen-forms gen-rpc gen-fixture-schemas
