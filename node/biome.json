{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "root": ".."
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.json",
      "!**/dist",
      "!**/node_modules",
      "!**/uc-client/src/uc-api.d.ts",
      "!**/ui/src/lib/forms/schemas",
      "!**/ui/src/lib/fixtures/schemas",
      "!**/ui/src/gen"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "style": {
        "noDefaultExport": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "ui/src/routes/**",
        "**/vite.config.ts",
        "**/*.stories.tsx",
        "ui/.storybook/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["ui/src/**", "!ui/src/features/data-grid/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/features/data-grid/**"],
                    "message": "Import from the data-grid barrel '@/features/data-grid', not its internals."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["ui/src/**", "!ui/src/features/unity-catalog/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/features/unity-catalog/**"],
                    "message": "Import from the unity-catalog barrel '@/features/unity-catalog', not its internals."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["ui/src/features/data-grid/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/lib/uc/**",
                      "@/features/unity-catalog",
                      "@/features/unity-catalog/**",
                      "@/components/catalog/**",
                      "@/components/storage/**",
                      "@/components/editor/**",
                      "@/components/environment/**",
                      "@/routes/**"
                    ],
                    "message": "data-grid is a leaf: it must not import Unity Catalog or app-feature code."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
