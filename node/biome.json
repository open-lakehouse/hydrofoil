{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "root": ".."
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.json",
      "!**/dist",
      "!**/node_modules",
      "!**/uc-client/src/uc-api.d.ts",
      "!**/unity-catalog/src/forms/schemas",
      "!**/ui/src/lib/fixtures/schemas",
      "!**/ui/src/gen"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "style": {
        "noDefaultExport": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "ui/src/routes/**",
        "**/vite.config.ts",
        "**/*.stories.tsx",
        "ui/.storybook/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["data-grid/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@open-lakehouse/unity-catalog"],
                    "message": "data-grid is a leaf: it must not import Unity Catalog. The Unity Catalog package may build on data-grid, never the reverse."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
