# Per-user Unity Catalog tokens for the demo notebooks. Copy to `notebooks/.env`
# (gitignored) and fill in real tokens, or run `just mint-demo-tokens` to mint
# and write them automatically.
#
# marimo auto-loads `notebooks/.env` (see notebooks/pyproject.toml) so the
# notebooks read these as ordinary environment variables. `_demo_auth.py` maps a
# user email to its env-var name: alice@example.com -> UC_TOKEN_ALICE.
#
# A missing token degrades gracefully: that user's queries fall back to
# hydrofoil's shared server-wide UC token (no per-user enforcement).

# Optional: the demo roster (comma-separated emails). Defaults to
# alice@example.com,bob@example.com when unset.
# UC_DEMO_USERS=alice@example.com,bob@example.com

# Per-user UC bearer tokens (mint with the sibling repo's create-user-jwt.sh).
UC_TOKEN_ALICE=
UC_TOKEN_BOB=
