# Stage 1: Build the Rust binary.
#
# The lineage proto Rust types are committed under src/proto/ (generated by
# `make rust-gen`), so the build needs neither buf nor protoc — it compiles
# straight from source.
FROM rust:1-bookworm AS build
ARG CRATES_PROXY=
WORKDIR /src
COPY crates/table-service/ .
COPY Cargo.lock ./Cargo.lock
RUN if [ -n "${CRATES_PROXY}" ]; then \
      proxy_url="${CRATES_PROXY}"; \
      case "${proxy_url}" in \
        sparse+*) ;; \
        *) proxy_url="sparse+${proxy_url}" ;; \
      esac; \
      mkdir -p /usr/local/cargo; \
      printf '[source.crates-io]\nreplace-with = "proxy"\n\n[source.proxy]\nregistry = "%s"\n' "${proxy_url}" > /usr/local/cargo/config.toml; \
      echo "Using CRATES_PROXY for cargo registry: ${proxy_url}"; \
    fi
RUN cargo build --release

# Stage 3: Minimal runtime image.
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*
COPY --from=build /src/target/release/table-service /table-service
ENV TABLE_SERVICE_PORT=8091
EXPOSE 8091
ENTRYPOINT ["/table-service"]
